DATABASE_URL="mysql://root:password@127.0.0.1:3306/my_portfolio"
AUTH_SECRET="ganti-dengan-random-secret-yang-panjang"
# Digunakan untuk bootstrap awal melalui `bun run db:seed`, bukan fallback login runtime.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ganti-dengan-password-admin-yang-kuat"
UPSTASH_REDIS_REST_URL="https://<your-db>.upstash.io"
UPSTASH_REDIS_REST_TOKEN="<upstash-rest-token>"
# Wajib diisi pada production agar rate limiting multi-instance tetap konsisten.
AUDIT_LOG_RETENTION_DAYS="90"
AUDIT_FAILED_LOGIN_ALERT_THRESHOLD="10"
AUDIT_FAILED_LOGIN_ALERT_WINDOW_MINUTES="15"
AUDIT_EXPORT_MAX_ROWS="500"
AUDIT_EXPORT_MAX_DAYS="31"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_CONTACT_EMAIL="hello@example.com"
NEXT_PUBLIC_GITHUB_URL="https://github.com/username"
NEXT_PUBLIC_LINKEDIN_URL="https://www.linkedin.com/in/username/"
