generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum SupportTransactionStatus {
  pending
  success
  failed
  expired
}

model AdminUser {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  auditLogs    AuditLog[]
}

model Project {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  category       String
  summary        String   @db.Text
  description    String   @db.Text
  body           String   @db.LongText
  tutorial       String?  @db.LongText
  thumbnailPath  String?
  demoUrl        String?
  repoUrl        String?
  techStack      Json
  features       Json
  published      Boolean  @default(false)
  featured       Boolean  @default(false)
  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([published, featured, publishedAt, updatedAt])
  @@index([updatedAt])
}

model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  category      String
  summary       String   @db.Text
  content       String   @db.LongText
  tags          Json
  coverImage    String?
  published     Boolean  @default(false)
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([published, publishedAt, updatedAt])
  @@index([updatedAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  status    String   @default("unread")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
}

model AuditLog {
  id          String     @id @default(cuid())
  actorId     String?
  actorEmail  String
  action      String
  entityType  String
  entityId    String?
  entityLabel String?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime   @default(now())
  actor       AdminUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([actorEmail, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([createdAt])
}

model SupportTransaction {
  id                   String                   @id @default(cuid()) @map("id")
  customRef            String                   @unique @map("custom_ref")
  trxId                String                   @unique @map("trx_id")
  username             String                   @map("username")
  supporterName        String?                  @map("supporter_name")
  supporterIdentityHash String?                 @map("supporter_identity_hash")
  isAnonymous          Boolean                  @default(false) @map("is_anonymous")
  message              String?                  @db.Text @map("message")
  showOnLeaderboard    Boolean                  @default(false) @map("show_on_leaderboard")
  amount               Int                      @map("amount")
  qrisPayload          String                   @db.LongText @map("qris_payload")
  status               SupportTransactionStatus @default(pending) @map("status")
  vendor               String?                  @map("vendor")
  rrn                  String?                  @map("rrn")
  merchantId           String?                  @map("merchant_id")
  rawGenerate          Json?                    @map("raw_generate")
  rawWebhook           Json?                    @map("raw_webhook")
  expiresAt            DateTime                 @map("expires_at")
  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @updatedAt @map("updated_at")
  finishedAt           DateTime?                @map("finished_at")

  @@index([status, createdAt])
  @@index([username, status])
  @@index([merchantId, status])
  @@index([status, showOnLeaderboard, supporterIdentityHash])
  @@index([supporterIdentityHash, finishedAt])
  @@map("support_transactions")
}
