generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model AdminUser {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  auditLogs    AuditLog[]
}

model Project {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  category       String
  summary        String   @db.Text
  description    String   @db.Text
  body           String   @db.LongText
  tutorial       String?  @db.LongText
  thumbnailPath  String?
  demoUrl        String?
  repoUrl        String?
  techStack      Json
  features       Json
  published      Boolean  @default(false)
  featured       Boolean  @default(false)
  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([published, featured, publishedAt, updatedAt])
  @@index([updatedAt])
}

model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  category      String
  summary       String   @db.Text
  content       String   @db.LongText
  tags          Json
  coverImage    String?
  published     Boolean  @default(false)
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([published, publishedAt, updatedAt])
  @@index([updatedAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  status    String   @default("unread")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([createdAt])
}

model AuditLog {
  id          String     @id @default(cuid())
  actorId     String?
  actorEmail  String
  action      String
  entityType  String
  entityId    String?
  entityLabel String?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime   @default(now())
  actor       AdminUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([actorEmail, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([createdAt])
}
